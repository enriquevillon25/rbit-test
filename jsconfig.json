{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "components/*": ["src/components/*"],
            "data/*": ["src/data/*"],
            "lib/*": ["src/lib/*"],
            "locales/*": ["src/locales/*"],
            "public/*": ["public/*"],
            "theme/*": ["src/theme/*"],
            "utils/*": ["src/utils/*"],
            "vendors/*": ["src/vendors/*"],
            "next-i18next.config": ["next-i18next.config.js"]
        }
    }
}
